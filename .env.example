# Copy this file to .env and fill in the values.
# The app will display a clear error at startup if required values are missing.

# Required when LLM_PROVIDER=claude (the default)
ANTHROPIC_API_KEY=your-key-here

# Optional overrides
# ANTHROPIC_MODEL=claude-sonnet-4-6        # Claude model to use
# LLM_PROVIDER=claude                      # claude | ollama | internal
# OLLAMA_MODEL=llama3.2:3b                 # Ollama model (if LLM_PROVIDER=ollama)
# OLLAMA_BASE_URL=http://localhost:11434   # Ollama server URL

# Tesseract OCR path (only needed for scanned PDFs)
# macOS (Homebrew):  TESSERACT_CMD=/usr/local/bin/tesseract
# Linux:             TESSERACT_CMD=/usr/bin/tesseract
# Windows default:   C:\Program Files\Tesseract-OCR\tesseract.exe
# TESSERACT_CMD=/usr/local/bin/tesseract
